{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tokmint.local/schemas/profile.schema.json",
  "title": "tokmint profile",
  "description": "YAML profile for tokmint (Mode A static tokens, Mode B OAuth).",
  "type": "object",
  "required": ["domains"],
  "additionalProperties": false,
  "properties": {
    "domains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/domainRow"
      }
    }
  },
  "$defs": {
    "headerPair": {
      "type": "object",
      "required": ["key", "value"],
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string"
        }
      }
    },
    "domainRow": {
      "type": "object",
      "required": ["domain"],
      "additionalProperties": false,
      "properties": {
        "domain": {
          "type": "string",
          "minLength": 1,
          "description": "ASCII hostname (no scheme)."
        },
        "tokens": {
          "type": "object",
          "propertyNames": {
            "pattern": "^[A-Za-z][A-Za-z0-9+.-]*$"
          },
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/credentialEntry"
            }
          }
        },
        "auth_servers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/authServer"
          }
        }
      }
    },
    "credentialEntry": {
      "type": "object",
      "required": ["token_id", "credential"],
      "additionalProperties": false,
      "properties": {
        "token_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-zA-Z0-9_-]+$"
        },
        "credential": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "authServer": {
      "type": "object",
      "required": ["path", "clients"],
      "additionalProperties": false,
      "properties": {
        "path": {
          "type": "string",
          "minLength": 1,
          "description": "Path-absolute token endpoint path.",
          "pattern": "^/"
        },
        "request_headers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/headerPair"
          }
        },
        "form_extra": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "clients": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/oauthClient"
          }
        }
      }
    },
    "oauthClient": {
      "type": "object",
      "required": ["client_id", "client_authn_method"],
      "additionalProperties": false,
      "properties": {
        "client_id": {
          "type": "string",
          "minLength": 1
        },
        "client_authn_method": {
          "type": "string",
          "enum": [
            "client_secret_post",
            "client_secret_basic",
            "private_key_jwt"
          ]
        },
        "client_secret": {
          "type": "string",
          "minLength": 1
        },
        "scopes": {
          "type": "string",
          "minLength": 1
        },
        "private_key_jwt": {
          "type": "object",
          "required": ["assertion_iss"],
          "additionalProperties": false,
          "properties": {
            "assertion_iss": {
              "type": "string",
              "minLength": 1
            },
            "assertion_sub": {
              "type": "string",
              "minLength": 1
            },
            "assertion_aud": {
              "type": "string",
              "minLength": 1
            },
            "assertion_ttl_seconds": {
              "type": "integer",
              "minimum": 1,
              "maximum": 3600
            }
          }
        },
        "signing_keys": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/signingKey"
          }
        },
        "dpop": {
          "type": "object",
          "required": ["enabled"],
          "additionalProperties": false,
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "signing_keys": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              },
              "description": "Allowlist of kid values allowed for DPoP."
            }
          }
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "client_authn_method": {
                "const": "private_key_jwt"
              }
            },
            "required": ["client_authn_method"]
          },
          "then": {
            "required": ["signing_keys", "private_key_jwt"]
          }
        },
        {
          "if": {
            "properties": {
              "client_authn_method": {
                "enum": [
                  "client_secret_post",
                  "client_secret_basic"
                ]
              }
            },
            "required": ["client_authn_method"]
          },
          "then": {
            "required": ["client_secret"]
          }
        },
        {
          "if": {
            "properties": {
              "dpop": {
                "properties": {
                  "enabled": {
                    "const": true
                  }
                },
                "required": ["enabled"]
              }
            },
            "required": ["dpop"]
          },
          "then": {
            "required": ["signing_keys"]
          }
        }
      ]
    },
    "signingKey": {
      "type": "object",
      "required": ["kid"],
      "additionalProperties": false,
      "properties": {
        "kid": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-zA-Z0-9_-]+$",
          "description": "Key ID: used both as the profile identifier and as the kid claim in the JWT header."
        },
        "encrypted_pem_path": {
          "type": "string",
          "minLength": 1
        },
        "jwk": {
          "type": "object",
          "minProperties": 1
        }
      },
      "oneOf": [
        {
          "required": ["kid", "encrypted_pem_path"],
          "not": {
            "required": ["jwk"]
          }
        },
        {
          "required": ["kid", "jwk"],
          "not": {
            "required": ["encrypted_pem_path"]
          }
        }
      ]
    }
  }
}
