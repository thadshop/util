{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://tokmint.local/schemas/profile.schema.json",
  "title": "tokmint profile",
  "description": "YAML profile for tokmint (Mode A static tokens, Mode B OAuth). Runtime may ignore keys not listed here (forward compatibility); this schema is strict for authoring and CI.",
  "type": "object",
  "required": ["domains"],
  "additionalProperties": false,
  "properties": {
    "oauth": {
      "$ref": "#/$defs/oauth"
    },
    "domains": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/domainRow"
      }
    }
  },
  "$defs": {
    "oauth": {
      "type": "object",
      "required": ["token_path"],
      "additionalProperties": false,
      "properties": {
        "token_path": {
          "type": "string",
          "minLength": 1,
          "description": "Path-absolute; joined with https:// + domain to form the OAuth token URL (e.g. /oauth2/default/v1/token).",
          "pattern": "^/"
        },
        "request_headers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/headerPair"
          }
        }
      }
    },
    "headerPair": {
      "type": "object",
      "required": ["key", "value"],
      "additionalProperties": false,
      "properties": {
        "key": {
          "type": "string",
          "minLength": 1
        },
        "value": {
          "type": "string"
        }
      }
    },
    "domainRow": {
      "type": "object",
      "required": ["domain"],
      "additionalProperties": false,
      "properties": {
        "domain": {
          "type": "string",
          "minLength": 1,
          "description": "ASCII hostname (no scheme); matched case-insensitively after canonical_domain in app code."
        },
        "tokens": {
          "type": "object",
          "description": "Maps Authorization scheme (e.g. SSWS, Bearer) to a non-empty list of { token_id, credential }. token_id must be unique within the domain row across all schemes.",
          "propertyNames": {
            "pattern": "^[A-Za-z][A-Za-z0-9+.-]*$"
          },
          "additionalProperties": {
            "type": "array",
            "minItems": 1,
            "items": {
              "$ref": "#/$defs/credentialEntry"
            }
          }
        },
        "clients": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/oauthClient"
          }
        }
      }
    },
    "credentialEntry": {
      "type": "object",
      "required": ["token_id", "credential"],
      "additionalProperties": false,
      "properties": {
        "token_id": {
          "type": "string",
          "minLength": 1,
          "description": "Single path segment style id (alphanumeric, _, -); unique per domain row across all schemes.",
          "pattern": "^[a-zA-Z0-9_-]+$"
        },
        "credential": {
          "type": "string",
          "minLength": 1,
          "description": "Secret credential; maps to JSON access_token. May be sops-encrypted in file."
        }
      }
    },
    "oauthClient": {
      "type": "object",
      "required": ["client_id"],
      "additionalProperties": false,
      "properties": {
        "client_id": {
          "type": "string",
          "minLength": 1
        },
        "client_secret": {
          "type": "string",
          "minLength": 1,
          "description": "For shared-secret OAuth; omit when using signing_keys only."
        },
        "scopes": {
          "type": "string",
          "minLength": 1,
          "description": "Reserved for fixed token-request scopes (Mode B)."
        },
        "signing_keys": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/signingKey"
          }
        }
      }
    },
    "signingKey": {
      "type": "object",
      "required": ["key_id", "encrypted_pem_path"],
      "additionalProperties": false,
      "properties": {
        "key_id": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[a-zA-Z0-9_-]+$",
          "description": "Matches query parameter key_id."
        },
        "encrypted_pem_path": {
          "type": "string",
          "minLength": 1,
          "description": "Path to OpenSSL ciphertext (e.g. under SECCONFIG_DIR)."
        }
      }
    }
  }
}
